# ── DeepSeek ──── https://api-docs.deepseek.com/quick_start/pricing ──────────
# Model name: "deepseek-chat" (recommended) or "deepseek-flash" (cheaper, faster).
# Current pricing (2025): deepseek-chat $0.14/1M input, $0.28/1M output;
#                         deepseek-flash $0.014/1M input, $0.028/1M output.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-flash

# ── Logging ───────────────────────────────────────────────────────────────────
AGENT_UIA_LOG_LEVEL=INFO
